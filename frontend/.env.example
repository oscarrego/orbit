# Orbit Firebase placeholders
# Copy these into your real deployment env later and replace the values.

# Set to true only after real Firebase config + Web Push certificate are ready.
REACT_APP_FIREBASE_ENABLED=false
VITE_FIREBASE_ENABLED=false

REACT_APP_FIREBASE_API_KEY=PASTE_REAL_FIREBASE_API_KEY_HERE
REACT_APP_FIREBASE_AUTH_DOMAIN=PASTE_REAL_FIREBASE_AUTH_DOMAIN_HERE
REACT_APP_FIREBASE_PROJECT_ID=PASTE_REAL_FIREBASE_PROJECT_ID_HERE
REACT_APP_FIREBASE_STORAGE_BUCKET=PASTE_REAL_FIREBASE_STORAGE_BUCKET_HERE
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=PASTE_REAL_FIREBASE_MESSAGING_SENDER_ID_HERE
REACT_APP_FIREBASE_APP_ID=PASTE_REAL_FIREBASE_APP_ID_HERE
REACT_APP_FIREBASE_MEASUREMENT_ID=PASTE_REAL_FIREBASE_MEASUREMENT_ID_HERE
REACT_APP_FIREBASE_VAPID_KEY=PASTE_REAL_WEB_PUSH_VAPID_KEY_HERE

VITE_FIREBASE_API_KEY=PASTE_REAL_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=PASTE_REAL_FIREBASE_AUTH_DOMAIN_HERE
VITE_FIREBASE_PROJECT_ID=PASTE_REAL_FIREBASE_PROJECT_ID_HERE
VITE_FIREBASE_STORAGE_BUCKET=PASTE_REAL_FIREBASE_STORAGE_BUCKET_HERE
VITE_FIREBASE_MESSAGING_SENDER_ID=PASTE_REAL_FIREBASE_MESSAGING_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=PASTE_REAL_FIREBASE_APP_ID_HERE
VITE_FIREBASE_MEASUREMENT_ID=PASTE_REAL_FIREBASE_MEASUREMENT_ID_HERE
VITE_FIREBASE_VAPID_KEY=PASTE_REAL_WEB_PUSH_VAPID_KEY_HERE

